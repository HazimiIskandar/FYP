# ---------------------------------------------------------------------------------
# Sample environment file for the senior-care backend.
#
#   - Copy this file: cp backend_api/.env.example backend_api/.env
#   - Fill the empty values below with real secrets (do NOT commit the .env).
#   - .gitignore already excludes `.env` but explicitly ALLOWS `*.env.example`,
#     so this template is safe to track.
#
# All these vars are read by either:
#   - backend_api/config/db.js        (MySQL)
#   - backend_api/services/telegramService.js  (TELEGRAM_BOT_TOKEN)
#   - backend_api/services/servicenow.js       (SN_*)
#   - backend_api/server.js          (PORT)
# ---------------------------------------------------------------------------------

# ===== Server ============================================================
NODE_ENV=development
PORT=10000

# ===== MySQL =============================================================
# Today these are hard-coded inside backend_api/config/db.js, but listing
# them here so you can flip the file to read from env in the future
# without having to look up the values.
MYSQL_HOST=cplofo.h.filess.io
MYSQL_PORT=61032
MYSQL_USER=senior_connect_curiousago
MYSQL_PASSWORD=fe9c8311734fbb029d7fec8b715366ee54ec0751
MYSQL_DATABASE=senior_connect_curiousago
MYSQL_TIMEZONE=+08:00

# ===== Telegram (BotFather) ==============================================
# Get from @BotFather in Telegram: /newbot → /token → copy the returned token.
# Without this set, telegramService.notifyCheckIn() will silently skip
# check-in fan-out (the rest of the check-in still works).
TELEGRAM_BOT_TOKEN=8820196711:AAGq1sQsrhj0tyb8Nwdbe6bva_i9LQp8LQk

# The actual chat IDs for caregivers / NOKs / AIC staff live in
# backend_api/telegramRecipients.js — edit that file directly to fill in
# the empty strings inside the caregiver_aic / caregiver_nok_aic arrays.
# (Telegram chat_id examples: "123456789" or "-1001234567890" for groups.)

# ===== ServiceNow (REST Table API for u_checkin_response) ===============
# Without SN_USERNAME / SN_PASSWORD the servicenow client silently skips
# the POST and lets the rest of the check-in succeed.
SN_INSTANCE_URL=https://dev316146.service-now.com
SN_USERNAME=admin
SN_PASSWORD=R9zu+*3kXIPa
SN_TABLE=u_checkin_response
SN_TIMEOUT_MS=5000

# ===== Optional: Notification audit row =================================
# Only needed if you later move from callback-style to async/await
# notification writes. Today the row is hard-coded to 'Sent'.
# NOTIFICATION_DEFAULT_STATUS=Sent
