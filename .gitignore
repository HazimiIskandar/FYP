# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env
.env.*
# Explicit allow-list entry so deployable .env.example templates can still be tracked.
!*.env.example

# ============================================================
# Secrets & runtime artefacts (added for Telegram bot integration)
# ============================================================
# Telegram bot token-bearing files (curl payloads, recipient maps, etc.)
body.json
*token*.json
telegram_recipients*.json
# Backend-specific snapshot/style files that occasionally surface secrets
backend_api/.env
backend_api/**/.env

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Ignore literal nul shadow files on Windows (Windows reserved device name nul shadows them from standard deletion APIs)
nul
